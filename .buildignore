# =========================================================
# NOBLEMENS BUILD IGNORE CONFIG
# =========================================================
# Controls which files/folders are excluded from:
# - HTML page scanning
# - Build input detection
#
# Uses glob-style patterns (micromatch compatible)
# =========================================================


# =========================================================
# DEPENDENCIES
# =========================================================
# Node dependencies (never part of build input)
node_modules/**


# =========================================================
# BUILD OUTPUT
# =========================================================
# Prevent recursive inclusion of generated files
dist/**


# =========================================================
# VERSION CONTROL
# =========================================================
# Git metadata
.git/**


# =========================================================
# SOURCE / INTERNAL SYSTEM FILES
# =========================================================
# Application logic (not routeable pages)
src/**
templates/**

# Build & utility scripts
scripts/**

# Config files (safety)
*.config.*
vite.config.*


# =========================================================
# CONTENT SYSTEM (MARKDOWN)
# =========================================================
# Raw content files (processed separately, never directly routed)
content/**

# Explicitly ignore all markdown files
**/*.md


# =========================================================
# LOCAL / DEVELOPMENT FILES
# =========================================================
# Personal notes, drafts, experiments
Dev Notes/**

# Optional future folders
drafts/**
experiments/**


# =========================================================
# SYSTEM / OS FILES (optional but safe)
# =========================================================
.DS_Store
Thumbs.db